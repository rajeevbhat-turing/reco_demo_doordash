{
  "name": "my-v0-project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint && next lint --dir store",
    "lint:fix": "next lint --fix && next lint --fix --dir store",
    "test:e2e:install": "playwright install --with-deps",
    "test:e2e:verify": "node tests/e2e/verify-setup.js",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:chromium": "playwright test --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:confirmed": "playwright test tests/e2e/tests/confirmed --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:orders": "playwright test tests/e2e/tests/confirmed/orders/orders.spec.ts --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:orders:outside": "playwright test tests/e2e/tests/development/orders/orders-outside-delivery.spec.ts --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:dev": "playwright test tests/e2e/tests/development --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:auth": "playwright test tests/e2e/tests/development/auth --config=tests/e2e/playwright.config.ts",
    "test:e2e:auth:signin": "playwright test tests/e2e/tests/development/auth/login.spec.ts --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:auth:signup": "playwright test tests/e2e/tests/development/auth/signup.spec.ts --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:address": "playwright test tests/e2e/tests/development/address --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:store": "playwright test tests/e2e/tests/development/store --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:reviews": "playwright test tests/e2e/tests/development/reviews --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:reorder": "playwright test tests/e2e/tests/development/reorder --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:checkout": "playwright test tests/e2e/tests/development/checkout --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:fundamentals": "playwright test tests/e2e/tests/development/fundamentals --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:fundamentals:ui": "playwright test tests/e2e/tests/development/fundamentals --config=tests/e2e/playwright.config.ts --ui",
    "test:e2e:ui": "playwright test --config=tests/e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config=tests/e2e/playwright.config.ts --headed",
    "test:e2e:debug": "playwright test --config=tests/e2e/playwright.config.ts --debug",
    "debug:chromium": "playwright test --config=tests/e2e/playwright.config.ts --project=chromium --debug",
    "test:e2e:report": "playwright show-report tests/e2e/playwright-report",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:ci": "vitest run --coverage --reporter=verbose --no-color",
    "typecheck": "tsc --noEmit",
    "typecheck:ci": "node scripts/check-tsc.mjs"
  },
