{
  "add-fruits": {
    "prompt": "Add 3 kiwis, 1 avocado, and 1 bunch of strawberries from Gus's Community Market to your cart",
    "assertions": [
      {
        "title": "Cart should contain exactly 3 unique items",
        "operator": "JSON_MATCH",
        "path": "multicategory-cart.state.items.length",
        "expected": 3
      },
      {
        "title": "Cart should contain 3 Kiwis",
        "operator": "JSON_MATCH",
        "path": "multicategory-cart.state.items[?(@.itemName=='Kiwi')].quantity",
        "expected": 3
      },
      {
        "title": "Cart should contain 1 Avocado",
        "operator": "JSON_MATCH",
        "path": "multicategory-cart.state.items[?(@.itemName=='Avocado')].quantity",
        "expected": 1
      },
      {
        "title": "Cart should contain 1 Strawberries",
        "operator": "JSON_MATCH",
        "path": "multicategory-cart.state.items[?(@.itemName=='Strawberries')].quantity",
        "expected": 1
      },
      {
        "title": "Current store for the first item should be Gus's Community Market",
        "operator": "JSON_MATCH",
        "path": "multicategory-cart.state.items[0].storeName",
        "expected": "Gus's Community Market"
      },
      {
        "title": "Current store for the second item should be Gus's Community Market",
        "operator": "JSON_MATCH",
        "path": "multicategory-cart.state.items[1].storeName",
        "expected": "Gus's Community Market"
      },
      {
        "title": "Current store for the third item should be Gus's Community Market",
        "operator": "JSON_MATCH",
        "path": "multicategory-cart.state.items[2].storeName",
        "expected": "Gus's Community Market"
      }
    ]
  }
}
