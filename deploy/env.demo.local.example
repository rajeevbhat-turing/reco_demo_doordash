# Template for *local* runs of the demo stack (laptop, not the VM).
#
# Usage:
#   cp deploy/env.demo.local.example deploy/env.demo.local
#   # edit deploy/env.demo.local with your real keys
#   ENV_FILE=deploy/env.demo.local ./scripts/demo-up.sh
#
# The compose file (config/docker-compose.demo.yaml) is the same one
# the VM uses — sidecars reach each other via compose DNS, so the
# URLs below stay identical to deploy/env.demo.example. Only the
# place this file *lives* is different.
#
# deploy/env.demo.local is gitignored — do not commit real secrets.

# --- Dashdoor ---
RECO_DEMO=1
NODE_ENV=production
LIBSQL_URL=file:/app/dashdoor.db
DELIVERY_LIBSQL_URL=file:/app/delivery.db
MERCHANT_LIBSQL_URL=file:/app/merchant.db
PREFIX_URL=https://meta-ui-images.s3.us-west-2.amazonaws.com/

# --- Engine sidecars (compose DNS names; do not change for local) ---
RECO_GORSE_URL=http://gorse:8088
RECO_LIGHTFM_URL=http://lightfm:8001/recommend
RECO_IMPLICIT_URL=http://implicit:8002/recommend

# --- LLM agent (BYO keys — fill in at least one) ---
RECO_AGENT_URL=http://reco-agent:8003/recommend
RECO_AGENT_TARGET_URL=http://dashdoor:3000
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
RECO_AGENT_MODEL=claude-sonnet-4-6
RECO_AGENT_MAX_STEPS=25
# Local box has a display server, but the compose container doesn't.
# Keep headless = 1.
RECO_AGENT_HEADLESS=1
RECO_AGENT_TIMEOUT_MS=120000
