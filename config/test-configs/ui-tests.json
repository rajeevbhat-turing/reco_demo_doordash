{
  "testSuites": {
    "regression": {
      "name": "Regression Tests - UI Changes",
      "description": "Tests to ensure UI changes don't break existing verifiers",
      "testCases": [
        {
          "name": "Sweet Pretzel - Should Pass",
          "description": "Verifier should pass when cart contains exactly 1 sweet pretzel from Jamba Juice",
          "initialState": "cartWithSweetPretzel",
          "verifierId": "add-sweet-pretzel",
          "expectedResult": true,
          "timeout": 5000
        },
        {
          "name": "Clear Cart - Should Pass",
          "description": "Verifier should pass when cart was cleared with exactly 3 items",
          "initialState": "cartWithThreeItems",
          "verifierId": "clear-cart",
          "expectedResult": true,
          "timeout": 5000
        },
        {
          "name": "Safeway Milk - Should Pass",
          "description": "Verifier should pass when at Safeway with 1 milk item",
          "initialState": "atSafewayWithMilk",
          "verifierId": "add-milk-from-safeway",
          "expectedResult": true,
          "timeout": 5000
        },
        {
          "name": "Gus Market Fruits - Should Pass",
          "description": "Verifier should pass when at Gus Market with correct fruit quantities",
          "initialState": "atGusMarketWithFruits",
          "verifierId": "add-fruits",
          "expectedResult": true,
          "timeout": 5000
        },
        {
          "name": "Sweet Pretzel - Empty Cart Should Fail",
          "description": "Verifier should fail when cart is empty",
          "initialState": "emptyCart",
          "verifierId": "add-sweet-pretzel",
          "expectedResult": false,
          "timeout": 5000
        },
        {
          "name": "Clear Cart - Empty Cart Should Fail",
          "description": "Verifier should fail when no clear action was performed",
          "initialState": "emptyCart",
          "verifierId": "clear-cart",
          "expectedResult": false,
          "timeout": 5000
        },
        {
          "name": "Safeway Milk - Wrong Store Should Fail",
          "description": "Verifier should fail when not at Safeway",
          "initialState": "cartWithSweetPretzel",
          "verifierId": "add-milk-from-safeway",
          "expectedResult": false,
          "timeout": 5000
        }
      ]
    },
    "breaking": {
      "name": "Breaking Change Detection",
      "description": "Tests to detect breaking changes in verifiers or UI",
      "testCases": [
        {
          "name": "Verifier Already Consumed",
          "description": "Verifier should fail when already consumed",
          "initialState": "cartWithSweetPretzelConsumed",
          "verifierId": "add-sweet-pretzel",
          "expectedResult": false,
          "timeout": 5000
        },
        {
          "name": "Malformed Cart State",
          "description": "Verifier should handle malformed state gracefully",
          "initialState": "malformedState",
          "verifierId": "add-sweet-pretzel",
          "expectedResult": "error",
          "timeout": 5000
        }
      ]
    },
    "ui-changes": {
      "name": "UI Change Impact Tests",
      "description": "Tests to verify UI changes don't break verifiers",
      "testCases": [
        {
          "name": "Store Name Change Impact",
          "description": "Test if changing store names breaks verifiers",
          "initialState": "customStoreName",
          "verifierId": "add-sweet-pretzel",
          "expectedResult": false,
          "timeout": 5000
        },
        {
          "name": "Item Name Change Impact",
          "description": "Test if changing item names breaks verifiers",
          "initialState": "customItemName",
          "verifierId": "add-sweet-pretzel",
          "expectedResult": false,
          "timeout": 5000
        }
      ]
    }
  },
