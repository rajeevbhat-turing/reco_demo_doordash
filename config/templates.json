  {
    "template_type": "complex_order",
    "task_id": "009",
    "start_url": "https://dashdoor.rlgym.turing.com/home",
    "task_statement": "Log in using email '{{USER_EMAIL}}' and password '{{USER_PASSWORD}}'. Lets order desserts from {{RESTAURANT}}. But since I am on a diet make sure you pick the two different lowest calorie options. And also add {{ITEM_NAME}} for my nephew, keep the spice level {{SPICE_LEVEL}}. Apply the {{PROMO_CODE}} coupon. Use the card ending with {{CARD_LAST_FOUR}} for payment.",
    "task_type": "GUI Comprehension, Action Execution, Decision Making, Element Identification, Multi-Step Task Planning",
    "simulator_config": {
      "start_date": "today",
      "user_persona": "{{USER_EMAIL}}"
    },
    "grader_config": {
      "state_grader_configs": [
        {
          "assertions": [{"operator": "STRING_EQUALS", "paths_to_expected": ["$.deal.id"]}],
          "path_to_actual": "$.orders[0].appliedDeal.id"
        },
        {
          "assertions": [{"operator": "STRING_EQUALS", "paths_to_expected": ["$.paymentMethod.lastFour"]}],
          "path_to_actual": "$.orders[0].paymentCard.lastFour"
        },
        {
          "assertions": [
            {"operator": "ARRAY_STRING_EQUALS", "path_to_actual": "$.restaurantId", "paths_to_expected": ["$.restaurants[0].id"]},
            {"operator": "ARRAY_STRING_EQUALS", "path_to_actual": "$.items[*].name", "paths_to_expected": ["$.items[*].name"]},
            {"operator": "STRING_EQUALS", "path_to_actual": "$.items[?(@.name == '{{ITEM_NAME}}')].modifications[0].options[0].optionName", "expected": ["{{SPICE_LEVEL}}"]},
            {"expected": ["==3"], "operator": "ARRAY_LENGTH_MATCH", "path_to_actual": "$.items[*]"}
          ],
          "path_to_actual": "$.orders[0]"
        }
      ],
      "extract_states_config": {
        "expected_state_functions": [
          {"args": {"user": "{{USER_EMAIL}}"}, "function": "get_user_address"},
          {"args": {"promocode": "{{PROMO_CODE}}"}, "function": "get_deal"},
          {"args": {"lat": "$[0].address.lat", "lng": "$[0].address.lng", "limit": 1, "name": "{{RESTAURANT}}"}, "function": "get_restaurants"},
          {"args": {"limit": 2, "filters": {"menu_categories": ["desserts"]}, "sort_type": [{"key": "calories", "order": "asc"}], "restaurant_id": "$[2].restaurants[0].id"}, "function": "get_items"},
          {"args": {"limit": 1, "keywords": ["{{ITEM_KEYWORDS}}"], "restaurant_id": "$[2].restaurants[0].id"}, "function": "get_items"},
          {"args": {"filters": {"last_four_digits": "{{CARD_LAST_FOUR}}"}}, "function": "get_user_payment_method"}
