LIBSQL_URL=file:./data/db/dashdoor.db
DELIVERY_LIBSQL_URL=file:./data/db/delivery.db
MERCHANT_LIBSQL_URL=file:./data/db/merchant.db
PREFIX_URL=https://meta-ui-images.s3.us-west-2.amazonaws.com/

# --- Phase 4: LLM-agent track (tools/reco-agent/) ---
# Set RECO_AGENT_URL when the agent sidecar is reachable; absent → engine
# registry skips the `agent` entry and /reco-eval/agent stays unreachable.
RECO_AGENT_URL=
RECO_AGENT_PROVIDER=claude
ANTHROPIC_API_KEY=
# Optional: OpenAI fallback. Wire-up lives in tools/reco-agent/src/llm/openai.ts.
OPENAI_API_KEY=
